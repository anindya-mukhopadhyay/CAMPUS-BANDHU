rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['super_admin', 'college_admin'];
    }

    // 1. users
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin();
    }

    // 2. events
    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated(); // More specific rules should be added for organizers
    }

    // 3. registrations
    match /registrations/{regId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // 4. marketplace
    match /marketplace/{itemId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // 5. marketplaceChats
    match /marketplaceChats/{chatId} {
      allow read, write: if isAuthenticated();
    }

    // 6. chats
    match /chats/{chatId} {
      allow read, write: if isAuthenticated() && request.auth.uid in resource.data.participants;
    }

    // 7. notifications
    match /notifications/{notifId} {
      allow read: if isOwner(resource.data.userId);
      allow write: if isAdmin();
    }

    // 8. certificates
    match /certificates/{certId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // 9. analytics
    match /analytics/{docId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    // 10. aiRecommendations
    match /aiRecommendations/{userId} {
      allow read: if isOwner(userId);
      allow write: if isAdmin();
    }

    // 11. attendanceLogs
    match /attendanceLogs/{logId} {
      allow read, write: if isAdmin();
    }

    // 12. blockchainProofs
    match /blockchainProofs/{proofId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // 13. recruiterPosts
    match /recruiterPosts/{postId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated(); // Should be restricted to recruiter role
    }

    // 14. achievements
    match /achievements/{achId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // 15. clubs
    match /clubs/{clubId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // 16. reviews
    match /reviews/{reviewId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // 17. reports
    match /reports/{reportId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    // 18. leaderboards
    match /leaderboards/{boardId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
